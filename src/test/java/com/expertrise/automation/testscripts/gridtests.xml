<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="TestSuite" parallel="classes" thread-count="3">
	
	<groups>
		<run>
			<include name="GridTest" />
			<!--<include name="Actions" />-->
		</run>
	</groups>
	
	<!-- Grid Environments -->
	<test name="windows-chrome" enabled="true">
		<parameter name="os" value="windows"/>
		<parameter name="browser" value="chrome"/>
		<classes>
			   <class name="com.expertrise.automation.seleniumTraining.actions.ClickActionParallelExecution"/>
				<class name="com.expertrise.automation.seleniumTraining.webelements.AlertHandlingTestParallelTest"/>

		</classes>
	</test>
	<test name="windows-edge" enabled="true">
		<parameter name="os" value="windows"/>
		<parameter name="browser" value="edge"/>
		<classes>
			<class name="com.expertrise.automation.seleniumTraining.actions.ClickActionParallelExecution"/>
			<class name="com.expertrise.automation.seleniumTraining.webelements.AlertHandlingTestParallelTest"/>
		</classes>
	</test>
		
</suite>


